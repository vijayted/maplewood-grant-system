<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Amount_Under_50K</fullName>
    <active>true</active>
    <description>Amount requested cannot exceed $50,000</description>
    <errorConditionFormula>Amount_Requested__c &gt; 50000</errorConditionFormula>
    <errorDisplayField>Amount_Requested__c</errorDisplayField>
    <errorMessage>The requested amount cannot exceed $50,000.</errorMessage>
</ValidationRule>
