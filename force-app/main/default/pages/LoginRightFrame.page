<apex:page showHeader="false" sidebar="false" standardStylesheets="false" docType="html-5.0" applyBodyTag="false" applyHtmlTag="false" lightningStylesheets="false">
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Maplewood Staff Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(160deg, #0a1628 0%, #0f1d35 40%, #162a4a 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            color: #ffffff;
            overflow: hidden;
            position: relative;
        }

        .network-canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .node {
            position: absolute;
            border-radius: 50%;
            animation: float 6s ease-in-out infinite;
        }

        .node-core {
            width: 8px;
            height: 8px;
            background: rgba(251, 173, 24, 0.7);
            border-radius: 50%;
            box-shadow: 0 0 12px rgba(251, 173, 24, 0.3);
        }

        .node-ring {
            width: 12px;
            height: 12px;
            border: 1.5px solid rgba(255, 255, 255, 0.15);
            border-radius: 50%;
        }

        .node-lg .node-core {
            width: 14px;
            height: 14px;
            background: rgba(251, 173, 24, 0.5);
            box-shadow: 0 0 20px rgba(251, 173, 24, 0.2);
        }

        .node-sm .node-core {
            width: 5px;
            height: 5px;
            background: rgba(255, 255, 255, 0.25);
            box-shadow: none;
        }

        .n1 { top: 12%; left: 18%; animation-delay: 0s; }
        .n2 { top: 8%; left: 65%; animation-delay: 1.2s; }
        .n3 { top: 28%; left: 82%; animation-delay: 0.6s; }
        .n4 { top: 45%; left: 10%; animation-delay: 2s; }
        .n5 { top: 55%; left: 90%; animation-delay: 0.3s; }
        .n6 { top: 72%; left: 25%; animation-delay: 1.8s; }
        .n7 { top: 80%; left: 70%; animation-delay: 0.9s; }
        .n8 { top: 35%; left: 45%; animation-delay: 1.5s; }
        .n9 { top: 18%; left: 40%; animation-delay: 2.4s; }
        .n10 { top: 65%; left: 50%; animation-delay: 0.4s; }
        .n11 { top: 88%; left: 45%; animation-delay: 1.1s; }
        .n12 { top: 40%; left: 70%; animation-delay: 2.2s; }

        @keyframes float {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-8px) scale(1.05); }
        }

        .connection {
            position: absolute;
            height: 1px;
            background: linear-gradient(90deg, rgba(255,255,255,0.04), rgba(251,173,24,0.12), rgba(255,255,255,0.04));
            transform-origin: left center;
        }

        .c1  { top: 14%; left: 20%; width: 22%; transform: rotate(  -8deg); }
        .c2  { top: 10%; left: 43%; width: 24%; transform: rotate(  -4deg); }
        .c3  { top: 30%; left: 48%; width: 35%; transform: rotate(  -3deg); }
        .c4  { top: 46%; left: 12%; width: 34%; transform: rotate( -12deg); }
        .c5  { top: 38%; left: 48%; width: 24%; transform: rotate(  10deg); }
        .c6  { top: 56%; left: 52%; width: 38%; transform: rotate(  -2deg); }
        .c7  { top: 73%; left: 27%; width: 25%; transform: rotate(  -5deg); }
        .c8  { top: 67%; left: 52%; width: 20%; transform: rotate(  15deg); }
        .c9  { top: 82%; left: 47%; width: 24%; transform: rotate(  -8deg); }
        .c10 { top: 20%; left: 20%; width: 28%; transform: rotate(  30deg); }

        .content {
            position: relative;
            z-index: 1;
            max-width: 360px;
            text-align: center;
        }

        .county-seal {
            width: 64px;
            height: 64px;
            margin: 0 auto 1.5rem;
            border-radius: 50%;
            border: 2px solid rgba(251, 173, 24, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(251, 173, 24, 0.08);
            box-shadow: 0 0 30px rgba(251, 173, 24, 0.1);
        }

        .seal-icon {
            font-size: 1.75rem;
        }

        .county-label {
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.45);
            margin-bottom: 0.75rem;
        }

        .county-name {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1.2;
            margin-bottom: 0.5rem;
        }

        .county-name .highlight {
            background: linear-gradient(135deg, #FBAD18, #f0c65a);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .divider {
            width: 40px;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(251, 173, 24, 0.5), transparent);
            margin: 1.25rem auto;
        }

        .mission {
            font-size: 0.9rem;
            line-height: 1.7;
            color: rgba(255, 255, 255, 0.55);
            font-weight: 400;
            margin-bottom: 2rem;
        }

        .stats {
            display: flex;
            justify-content: center;
            gap: 2.5rem;
            margin-bottom: 2rem;
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #FBAD18;
            line-height: 1;
        }

        .stat-label {
            font-size: 0.65rem;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.35);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-top: 0.35rem;
        }

        .portal-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1.25rem;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 2rem;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.06em;
            color: rgba(255, 255, 255, 0.6);
        }

        .portal-dot {
            width: 6px;
            height: 6px;
            background: #22c55e;
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }
    </style>
</head>
<body>
    <div class="network-canvas">
        <div class="node n1"><div class="node-core"></div></div>
        <div class="node n2 node-sm"><div class="node-core"></div></div>
        <div class="node n3"><div class="node-ring"></div></div>
        <div class="node n4 node-sm"><div class="node-core"></div></div>
        <div class="node n5"><div class="node-core"></div></div>
        <div class="node n6 node-lg"><div class="node-core"></div></div>
        <div class="node n7 node-sm"><div class="node-core"></div></div>
        <div class="node n8"><div class="node-ring"></div></div>
        <div class="node n9 node-sm"><div class="node-core"></div></div>
        <div class="node n10"><div class="node-core"></div></div>
        <div class="node n11 node-sm"><div class="node-core"></div></div>
        <div class="node n12"><div class="node-ring"></div></div>

        <div class="connection c1"></div>
        <div class="connection c2"></div>
        <div class="connection c3"></div>
        <div class="connection c4"></div>
        <div class="connection c5"></div>
        <div class="connection c6"></div>
        <div class="connection c7"></div>
        <div class="connection c8"></div>
        <div class="connection c9"></div>
        <div class="connection c10"></div>
    </div>

    <div class="content">
        <div class="county-seal">
            <span class="seal-icon">&#9878;</span>
        </div>

        <div class="county-label">Est. 1835 &bull; Maryland</div>

        <h1 class="county-name">
            Maplewood<br/><span class="highlight">County</span>
        </h1>

        <div class="divider"></div>

        <p class="mission">
            Empowering communities through transparent grant funding.
            Building stronger neighborhoods, one project at a time.
        </p>

        <div class="stats">
            <div class="stat">
                <div class="stat-value">$2M</div>
                <div class="stat-label">Annual Fund</div>
            </div>
            <div class="stat">
                <div class="stat-value">250K</div>
                <div class="stat-label">Residents</div>
            </div>
            <div class="stat">
                <div class="stat-value">50+</div>
                <div class="stat-label">Nonprofits</div>
            </div>
        </div>

        <div class="portal-badge">
            <span class="portal-dot"></span>
            Staff Review Portal
        </div>
    </div>
</body>
</html>
</apex:page>
