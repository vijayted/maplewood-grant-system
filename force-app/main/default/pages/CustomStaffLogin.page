<apex:page controller="CustomStaffLoginController" showHeader="false" sidebar="false" standardStylesheets="false" docType="html-5.0" applyBodyTag="false" applyHtmlTag="false" lightningStylesheets="false">
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - Maplewood Grant Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
            display: flex;
            background: #f5f5f5;
        }

        .split-container {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        /* Left Panel */
        .left-panel {
            width: 45%;
            background: linear-gradient(160deg, #0a1628 0%, #122244 50%, #1a3358 100%);
            color: #ffffff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 3rem 3.5rem;
            position: relative;
            overflow: hidden;
        }

        .left-panel::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -30%;
            width: 80%;
            height: 120%;
            background: radial-gradient(ellipse, rgba(251,173,24,0.06) 0%, transparent 70%);
            pointer-events: none;
        }

        .left-panel::after {
            content: '';
            position: absolute;
            bottom: -20%;
            left: -20%;
            width: 60%;
            height: 60%;
            background: radial-gradient(ellipse, rgba(0,74,159,0.15) 0%, transparent 70%);
            pointer-events: none;
        }

        .brand-section {
            position: relative;
            z-index: 1;
        }

        .logo-container {
            margin-bottom: 2.5rem;
        }

        .logo-container img {
            height: 56px;
            width: auto;
        }

        .tagline {
            font-size: 2rem;
            font-weight: 700;
            line-height: 1.25;
            margin-bottom: 1.25rem;
            letter-spacing: -0.02em;
        }

        .tagline .accent {
            color: #FBAD18;
        }

        .description {
            font-size: 0.975rem;
            line-height: 1.65;
            color: rgba(255,255,255,0.7);
            margin-bottom: 2.5rem;
            max-width: 380px;
        }

        .feature-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.875rem;
            margin-bottom: 2.5rem;
        }

        .feature-card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 0.625rem;
            padding: 1rem;
            transition: background 0.2s;
        }

        .feature-card:hover {
            background: rgba(255,255,255,0.1);
        }

        .feature-icon {
            width: 32px;
            height: 32px;
            border-radius: 0.375rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            margin-bottom: 0.5rem;
        }

        .feature-icon.blue { background: rgba(0,74,159,0.4); }
        .feature-icon.green { background: rgba(26,101,42,0.4); }
        .feature-icon.amber { background: rgba(251,173,24,0.3); }
        .feature-icon.purple { background: rgba(120,80,160,0.4); }

        .feature-title {
            font-size: 0.8125rem;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 0.2rem;
        }

        .feature-desc {
            font-size: 0.6875rem;
            color: rgba(255,255,255,0.5);
            line-height: 1.4;
        }

        .status-bar {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.8125rem;
            color: rgba(255,255,255,0.5);
        }

        .status-dot {
            width: 8px;
            height: 8px;
            background: #22c55e;
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        /* Right Panel */
        .right-panel {
            width: 55%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem;
            background: #ffffff;
        }

        .login-container {
            width: 100%;
            max-width: 400px;
        }

        .avatar-circle {
            width: 52px;
            height: 52px;
            background: #0a1628;
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .avatar-circle svg {
            width: 24px;
            height: 24px;
            fill: #ffffff;
        }

        .welcome-title {
            font-size: 1.625rem;
            font-weight: 700;
            color: #0a1628;
            margin-bottom: 0.375rem;
            letter-spacing: -0.02em;
        }

        .welcome-subtitle {
            font-size: 0.9375rem;
            color: #6b7280;
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-label {
            display: block;
            font-size: 0.8125rem;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 0.375rem;
        }

        .form-input {
            width: 100%;
            padding: 0.75rem 0.875rem;
            border: 1.5px solid #e5e7eb;
            border-radius: 0.5rem;
            font-size: 0.9375rem;
            font-family: inherit;
            color: #1f2937;
            background: #ffffff;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-input::placeholder {
            color: #9ca3af;
        }

        .form-input:focus {
            border-color: #0a1628;
            box-shadow: 0 0 0 3px rgba(10,22,40,0.08);
            outline: none;
        }

        .btn-login {
            width: 100%;
            padding: 0.8125rem;
            background: #0a1628;
            color: #ffffff;
            border: none;
            border-radius: 0.5rem;
            font-size: 0.9375rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: background 0.2s;
            margin-top: 0.5rem;
        }

        .btn-login:hover {
            background: #122244;
        }

        .btn-login:focus-visible {
            outline: 2px solid #003068;
            outline-offset: 2px;
        }

        .links-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1rem;
        }

        .links-row a {
            font-size: 0.8125rem;
            color: #4b5563;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

        .links-row a:hover {
            color: #0a1628;
        }

        .divider {
            display: flex;
            align-items: center;
            margin: 1.75rem 0;
            color: #9ca3af;
            font-size: 0.6875rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #e5e7eb;
        }

        .divider::before { margin-right: 1rem; }
        .divider::after { margin-left: 1rem; }

        .footer-text {
            text-align: center;
            font-size: 0.75rem;
            color: #9ca3af;
            line-height: 1.5;
        }

        .footer-text a {
            color: #4b5563;
            text-decoration: none;
        }

        .footer-text a:hover {
            text-decoration: underline;
        }

        .error-banner {
            background-color: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            margin-bottom: 1.25rem;
            font-size: 0.875rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .error-icon {
            flex-shrink: 0;
            width: 18px;
            height: 18px;
        }

        /* Responsive */
        @media (max-width: 900px) {
            .split-container {
                flex-direction: column;
            }
            .left-panel {
                width: 100%;
                padding: 2rem 1.5rem;
                min-height: auto;
            }
            .right-panel {
                width: 100%;
                padding: 2rem 1.5rem;
            }
            .tagline {
                font-size: 1.5rem;
            }
            .feature-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 480px) {
            .feature-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Screen reader only */
        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0,0,0,0);
            white-space: nowrap;
            border: 0;
        }
    </style>
</head>
<body>
    <div class="split-container">
        <!-- Left Panel: Branding -->
        <div class="left-panel">
            <div class="brand-section">
                <div class="logo-container">
                    <img src="{!URLFOR($Resource.MaplewoodLogoWhite)}" alt="Maplewood County Grant System" />
                </div>

                <h1 class="tagline">
                    Apply for grants.<br/>
                    Build your community.<br/>
                    <span class="accent">Make impact.</span>
                </h1>

                <p class="description">
                    Maplewood County's Community Development Grant Program
                    supports local nonprofits with grants up to $50,000.
                </p>

                <div class="feature-grid">
                    <div class="feature-card">
                        <div class="feature-icon blue">&#128203;</div>
                        <div class="feature-title">Apply Online</div>
                        <div class="feature-desc">Simple two-section application form</div>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon green">&#9989;</div>
                        <div class="feature-title">Eligibility Check</div>
                        <div class="feature-desc">Real-time feedback as you apply</div>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon amber">&#128202;</div>
                        <div class="feature-title">Track Status</div>
                        <div class="feature-desc">Monitor your application progress</div>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon purple">&#128176;</div>
                        <div class="feature-title">Up to $50K</div>
                        <div class="feature-desc">Community development funding</div>
                    </div>
                </div>

                <div class="status-bar">
                    <span class="status-dot"></span>
                    Applications open year-round
                </div>
            </div>
        </div>

        <!-- Right Panel: Login Form -->
        <div class="right-panel">
            <div class="login-container" role="main">
                <div class="avatar-circle" aria-hidden="true">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                    </svg>
                </div>

                <h2 class="welcome-title">Welcome back</h2>
                <p class="welcome-subtitle">Sign in to your Grant Application Portal</p>

                <apex:form id="loginForm">
                    <div aria-live="assertive">
                        <apex:outputPanel rendered="{!errorMessage != ''}" layout="block" styleClass="error-banner">
                            <svg class="error-icon" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                            </svg>
                            {!errorMessage}
                        </apex:outputPanel>
                    </div>

                    <div class="form-group">
                        <label for="email" class="form-label">Email</label>
                        <apex:inputText id="email" value="{!username}" styleClass="form-input" html-placeholder="you@maplewood.gov" html-autocomplete="email" />
                    </div>

                    <div class="form-group">
                        <label for="pw" class="form-label">Password</label>
                        <apex:inputSecret id="pw" value="{!password}" styleClass="form-input" html-placeholder="Enter your password" redisplay="false" />
                    </div>

                    <apex:commandButton action="{!login}" value="Sign In" styleClass="btn-login" reRender="loginForm" />

                    <div class="links-row">
                        <apex:commandLink action="{!forgotPassword}" value="Forgot password?" styleClass="link" />
                        <apex:commandLink action="{!goToRegister}" value="Create an account" styleClass="link" />
                    </div>
                </apex:form>

                <div class="divider">Grant Portal</div>

                <div class="footer-text">
                    Need help? Contact <a href="mailto:grants@maplewood.gov">grants@maplewood.gov</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
</apex:page>
